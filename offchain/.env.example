# Network configuration
NETWORK=preprod  # preprod | mainnet
BLOCKFROST_API_KEY=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Test wallet (for providing UTxOs to build transactions)
TEST_WALLET_MNEMONIC=

# DD and Operator public key hashes (56 hex chars)
DD_VKEY=
OPERATOR_VKEY=

# Oracle NFT policy ID (set after running mintOracleNft)
ORACLE_NFT_POLICY_ID=

# Reference script location (set after running txOutRefScripts)
REF_SCRIPT_TX_HASH=
REF_SCRIPT_OUTPUT_INDEX=0
REF_SCRIPT_ADDRESS=  # Address to send ref scripts to (defaults to wallet address)

# Operator API URL (for depth-based tests)
OPERATOR_URL=http://localhost:3000
